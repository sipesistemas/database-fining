# Conexão com o ClickHouse usada pelo chfining.
# Copie para .env e ajuste. Carregue com:  set -a; . ./.env; set +a

# host:port no protocolo nativo (não use a porta HTTP 8123)
CH_ADDR=localhost:9000

# database para a conexão
CH_DATABASE=default

# usuário (precisa de SELECT nas tabelas system.*)
CH_USER=default

# senha — deixe vazio se o usuário não tiver senha
CH_PASSWORD=

# caminho dos dados do ClickHouse NA MÁQUINA onde o chfining roda
# (usado para estatísticas de disco; rode no próprio host do servidor)
CH_DATA_PATH=/var/lib/clickhouse
